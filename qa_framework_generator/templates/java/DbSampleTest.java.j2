package {{ base_package }}.db;

import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;
import org.testng.Assert;
import org.testng.annotations.AfterClass;
import org.testng.annotations.BeforeClass;
import org.testng.annotations.Test;

import java.util.List;
import java.util.Map;

/**
 * Demonstrates Spring JdbcTemplate-backed DB assertions using an H2 in-memory database.
 *
 * These tests run against H2 by default (no external DB required).
 * Override with: -Ddb.url=jdbc:mysql://host/schema -Ddb.username=qa -Ddb.password=secret
 */
public class DbSampleTest {

    private static final Logger log = LogManager.getLogger(DbSampleTest.class);
    private DbHelper db;

    @BeforeClass(alwaysRun = true)
    public void setUpDb() {
        db = DbHelper.fromSystemProperties();
        db.execute("CREATE TABLE IF NOT EXISTS sample_products (" +
                   "  id       INT PRIMARY KEY," +
                   "  name     VARCHAR(100) NOT NULL," +
                   "  category VARCHAR(50)," +
                   "  price    DECIMAL(10,2)" +
                   ")");
        db.update("INSERT INTO sample_products VALUES (1, 'Laptop Pro',   'Electronics', 1299.99)");
        db.update("INSERT INTO sample_products VALUES (2, 'Wireless Mouse','Electronics',  29.99)");
        db.update("INSERT INTO sample_products VALUES (3, 'Office Chair', 'Furniture',   349.00)");
        log.info("DB test schema and seed data created");
    }

    @AfterClass(alwaysRun = true)
    public void tearDownDb() {
        db.execute("DROP TABLE IF EXISTS sample_products");
        log.info("DB test schema dropped");
    }

    @Test(groups = {"db", "smoke"},
          description = "Verify row count after seed inserts")
    public void rowCountMatchesSeedData() {
        int count = db.count("sample_products");
        Assert.assertEquals(count, 3, "Expected 3 seed rows in sample_products");
    }

    @Test(groups = {"db", "regression"},
          description = "Query for a single product name by primary key")
    public void queryForSingleValueByPk() {
        String name = db.queryForObject(
                "SELECT name FROM sample_products WHERE id = ?", String.class, 1);
        Assert.assertEquals(name, "Laptop Pro", "Product name should match seed data");
    }

    @Test(groups = {"db", "regression"},
          description = "queryForList returns all rows in expected order")
    public void queryForListReturnsAllRows() {
        List<Map<String, Object>> rows = db.queryForList(
                "SELECT * FROM sample_products ORDER BY id");
        Assert.assertEquals(rows.size(), 3, "Should return all 3 seed rows");
        Assert.assertEquals(rows.get(0).get("NAME"), "Laptop Pro");
        Assert.assertEquals(rows.get(2).get("NAME"), "Office Chair");
    }

    @Test(groups = {"db", "regression"},
          description = "countWhere returns number of matching rows")
    public void countWhereCategoryFilter() {
        int electronics = db.countWhere("sample_products", "category = ?", "Electronics");
        Assert.assertEquals(electronics, 2, "Two Electronics products in seed data");
    }

    @Test(groups = {"db", "regression"},
          description = "exists returns true when matching row is found")
    public void existsReturnsTrueForKnownRow() {
        Assert.assertTrue(
                db.exists("sample_products", "name = ?", "Wireless Mouse"),
                "Wireless Mouse should exist in seed data");
    }

    @Test(groups = {"db", "regression"},
          description = "exists returns false when no matching row")
    public void existsReturnsFalseForUnknownRow() {
        Assert.assertFalse(
                db.exists("sample_products", "name = ?", "Unknown Product"),
                "Unknown Product should not exist");
    }

    @Test(groups = {"db", "regression"},
          description = "INSERT + DELETE via update() increments and restores count")
    public void insertAndDeleteMaintainsCount() {
        db.update("INSERT INTO sample_products VALUES (99, 'Temp Item', 'Test', 0.00)");
        Assert.assertEquals(db.count("sample_products"), 4, "Count should be 4 after insert");

        db.update("DELETE FROM sample_products WHERE id = 99");
        Assert.assertEquals(db.count("sample_products"), 3, "Count should be 3 after delete");
    }
}
